rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // Helper functions
    // ============================================
    
    function isValidComplaint() {
      return request.resource.data.keys().hasAll([
        'category', 'location', 'description', 'timestamp', 'status', 'priority'
      ]) && 
      request.resource.data.category in [
        'streetlight', 'water', 'garbage', 'roads', 'drainage',
        'electricity', 'encroachment', 'publictoilet', 'park', 'other'
      ] &&
      request.resource.data.status == 'open' &&
      request.resource.data.priority in ['low', 'medium', 'high'] &&
      request.resource.data.description.size() > 0 &&
      request.resource.data.description.size() <= 300 &&
      request.resource.data.location.size() > 0;
    }

    function isValidPhotoURL() {
      return !('photoURL' in request.resource.data) || 
             request.resource.data.photoURL == null ||
             (request.resource.data.photoURL is string && 
              request.resource.data.photoURL.matches('https://.*\\.(firebasestorage\\.app|cloudinary\\.com)/.*'));
    }

    function isAdmin() {
      // Allow any authenticated user to act as admin since there is no public signup
      return request.auth != null;
    }

    function isOnlyUpvoting() {
      let currentUpvotes = ('upvotes' in resource.data) ? resource.data.upvotes : 0;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes']) &&
             request.resource.data.upvotes == currentUpvotes + 1;
    }

    // ============================================
    // Complaints Collection
    // ============================================
    
    match /complaints/{complaintId} {
      // Anyone can read complaints (for the public map)
      allow read: if true;
      
      // Admins can fully update/delete. Public users can ONLY upvote.
      allow delete: if isAdmin();
      allow update: if isAdmin() || isOnlyUpvoting();
      
      // Anonymous users can create new complaints
      allow create: if 
        isValidComplaint() && 
        isValidPhotoURL();
    }

    // ============================================
    // Analytics/Stats (Optional future feature)
    // ============================================
    
    match /stats/{document=**} {
      allow read: if true;
      allow create, update, delete: if 
        request.auth != null && 
        request.auth.token.admin == true;
    }

    // ============================================
    // Deny all other access
    // ============================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
