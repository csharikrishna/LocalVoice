rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ============================================
    // Helper functions
    // ============================================
    
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isValidSize() {
      // Max 5MB for images
      return request.resource.size <= 5 * 1024 * 1024;
    }

    function isValidImageType() {
      return request.resource.contentType in [
        'image/jpeg',
        'image/png',
        'image/webp'
      ];
    }

    // ============================================
    // Complaints Photos
    // ============================================
    
    match /complaints/{complaintId}/{fileName} {
      // Create and Delete must be done via the server-side Admin SDK.
      // Do not allow direct client modifications to avoid abuse.
      allow create: if false;

      // Allow public read (anyone can view complaint photos)
      allow read: if true;

      allow delete: if false;
    }

    // ============================================
    // Deny all other access
    // ============================================
    
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
